# stow/wofi/.config/wofi/config
width=600
height=400
location=center
show=drun
prompt=Search...

# Case-insensitive matching — "firefox" and "Firefox" both hit
insensitive=true

# Fuzzy-ish matching by substring rather than requiring the match to
# start at the beginning of the string
matching=contains

# Uses GTK's dark theme preference as a baseline so it doesn't look like
# a jarring white box against everything else here being dark by default.
# Not a real theme system — just a reasonable placeholder until the
# launcher comparison lands.
gtk_dark=true

allow_images=true
image_size=24
